# MongoDB Atlas connection string
# Get from: atlas.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/online_fees_db?retryWrites=true&w=majority

# JWT secret — any long random string
JWT_SECRET=your_super_secret_key_change_this_in_production

# Environment
NODE_ENV=production
